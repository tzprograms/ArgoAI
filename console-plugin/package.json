{
  "name": "argocd-agent-console-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "OpenShift Console plugin for ArgoAgent AI diagnostics",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "yarn clean && yarn ts-node node_modules/webpack-cli/bin/cli.js --mode production",
    "start": "yarn ts-node node_modules/webpack-cli/bin/cli.js serve",
    "start-console": "./start-console.sh",
    "ts-node": "ts-node --project tsconfig.webpack.json",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@patternfly/react-core": "^6.4.0",
    "@patternfly/react-icons": "^6.4.0",
    "@patternfly/react-table": "^6.4.0",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-router": "5.3.4",
    "react-router-dom": "5.3.4"
  },
  "devDependencies": {
    "@openshift-console/dynamic-plugin-sdk": "^4.19.1",
    "@openshift-console/dynamic-plugin-sdk-webpack": "^4.19.1",
    "@types/react": "17.0.2",
    "@types/react-router-dom": "5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "css-loader": "^6.7.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.0",
    "sass": "^1.58.3",
    "sass-loader": "^13.2.0",
    "style-loader": "^3.3.1",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.1",
    "webpack-dev-server": "^4.11.1"
  },
  "consolePlugin": {
    "name": "argocd-agent-plugin",
    "version": "0.1.0",
    "displayName": "ArgoAI",
    "description": "AI-powered diagnostic agent for ArgoCD applications",
    "exposedModules": {
      "ArgoAgentPage": "./src/components/ArgoAgentPage"
    },
    "dependencies": {
      "@console/pluginAPI": "*"
    }
  }
}
